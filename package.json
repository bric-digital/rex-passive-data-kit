{
    "name": "@bric/rex-passive-data-kit",
    "version": "0.0.1",
    "description": "REX module for transmitting data to a Passive Data Kit server.",
    "keywords": [
        "extension",
        "rex"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "main": "index.mts",
    "homepage": "https://github.com/bric-digital/rex-passive-data-kit",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-passive-data-kit/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-passive-data-kit.git"
    },
    "exports": {
        "./extension": "./src/extension.mts",
        "./browser": "./src/browser.mts",
        "./service-worker": "./src/service-worker.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
        "test:ci": "playwright test --reporter=dot",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "playwright test specs/",
        "server": "node tests/scripts/run-server.js"
    },
    "dependencies": {
        "@bric/rex-content-processing": "github:bric-digital/rex-content-processing",
        "@bric/rex-core": "github:bric-digital/rex-core",
        "express": "^5.2.1",
        "json-stable-stringify": "^1.3.0",
        "multer": "^2.1.1",
        "tweetnacl": "^1.0.3",
        "tweetnacl-util": "^0.15.1"
    }
}
